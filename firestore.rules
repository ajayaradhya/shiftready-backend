rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Sale Events ──────────────────────────────────────────────────────────
    // Public read for LIVE sales (marketplace browsing).
    // Authenticated seller has full access to own sales.
    match /saleEvents/{eventId} {
      allow read: if resource.data.status == 'LIVE';
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.sellerId;
      allow create: if request.auth != null
        && request.resource.data.sellerId == request.auth.uid;

      // Bundles
      match /bundles/{bundleId} {
        allow read: if get(/databases/$(database)/documents/saleEvents/$(eventId)).data.status == 'LIVE';
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/saleEvents/$(eventId)).data.sellerId == request.auth.uid;

        // Items
        match /items/{itemId} {
          allow read: if get(/databases/$(database)/documents/saleEvents/$(eventId)).data.status == 'LIVE';
          allow read, write: if request.auth != null
            && get(/databases/$(database)/documents/saleEvents/$(eventId)).data.sellerId == request.auth.uid;
        }
      }

      // Conversations — participants only
      match /conversations/{conversationId} {
        allow read, write: if request.auth != null
          && (request.auth.uid in resource.data.participantIds
            || get(/databases/$(database)/documents/saleEvents/$(eventId)).data.sellerId == request.auth.uid);
        allow create: if request.auth != null
          && request.auth.uid in request.resource.data.participantIds;

        match /messages/{messageId} {
          allow read, write: if request.auth != null
            && request.auth.uid in get(
                /databases/$(database)/documents/saleEvents/$(eventId)/conversations/$(conversationId)
              ).data.participantIds;
        }
      }

      // Transactions — read by participants, no client writes
      match /transactions/{transactionId} {
        allow read: if request.auth != null
          && (request.auth.uid == resource.data.buyerId
            || request.auth.uid == resource.data.sellerId);
        allow write: if false;
      }
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{userId}/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
