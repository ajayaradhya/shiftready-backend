GCP_PROJECT_ID=<project-id>
GCP_SERVICE_ACCOUNT=<gcp-service-account-email>
# Prod: injected from Secret Manager secret "shiftready-gcp-upload-bucket" via Cloud Run --update-secrets.
# Local dev: set directly here.
GCP_UPLOAD_BUCKET=<gcp-bucket>
GCP_REGION=<region>
GOOGLE_APPLICATION_CREDENTIALS=./shiftready-backend-service-account.json

# Dev only — enables dev_ token bypass when K_SERVICE is absent. NEVER set true in prod.
ALLOW_DEV_TOKENS=true

# CORS origins — comma-separated JSON list. Prod value set via Cloud Run --update-env-vars in cloudbuild.yaml.
# Local dev: localhost is included by default (no override needed).
# Staging: ALLOWED_ORIGINS=["https://shiftready-backend-staging-<hash>.run.app","http://localhost:3000"]
# ALLOWED_ORIGINS=["https://shiftready-ui-12644234558.australia-southeast1.run.app"]

# GCS bucket access — in prod, Cloud Run default SA must have roles/storage.objectAdmin on the bucket.
# Verify bucket is private: gcloud storage buckets get-iam-policy gs://<bucket> | grep allUsers

# Sentry error tracking (optional for local dev; set in Cloud Run --update-env-vars for prod)
# SENTRY_DSN=

# One-time infra setup (run after first deploy):
#   GCS lifecycle rules:  bash scripts/gcs_lifecycle.sh $GCP_UPLOAD_BUCKET
#   Firestore notifs TTL: gcloud firestore fields ttls update expireAt --collection-group=notifications --project=$GCP_PROJECT_ID --enable-ttl
#   Budget + monitoring:  bash scripts/gcp_alerts.sh $GCP_PROJECT_ID <alert-email> <cloud-run-url>